@model Tuple<List<EmployeeApp.Data.Models.User>, List<EmployeeApp.PortalWithAuth.Models.UpcomingLeaveModel >>
@using NonFactors.Mvc.Grid
@using Microsoft.AspNetCore.Html
@{

    var returnUrl = "UpcomingLeaves";
}
<html>
<head>
    <link href="~/css/mvc-grid/mvc-grid.css" rel="stylesheet">
    <style>
        .bg-approved {
            background-color: #d4edda; /* Bootstrap success background color */
        }

        .bg-pending {
            background-color: #fff3cd; /* Bootstrap warning background color */
        }

        .bg-rejected {
            background-color: #f8d7da; /* Bootstrap danger background color */
        }

    </style>
</head>
<body>
   
    <h3>Upcoming Leaves</h3>
    @(
        Html.Grid(Model.Item2).Build(columns =>
        {


            columns.Add(model => model.Name).Titled("Associate Name").Filterable(true).Sortable(true);
            columns.Add(model => model.From).Titled("From").Filterable(true).Sortable(true);
            columns.Add(model => model.To).Titled("To").Filterable(true).Sortable(true);
            columns.Add(model => model.PurposeOfLeave).Titled("Purpose").Filterable(true).Sortable(true);
            //columns.Add(model => model.status).Titled("Status").Filterable(true).Sortable(true);
            columns.Add()
            .RenderedAs(model => new HtmlString($@"
    <a href='EditLeaveStatus?leaveId={model.leaveId}&returnUrl={returnUrl}'>{model.status}</a>"))
            .Titled("Status")
            .Css("text-center");
        })
        )
    <script src="~/js/mvc-grid/mvc-grid.js"></script>


    <script>
        document.querySelectorAll(".mvc-grid").forEach(element => new MvcGrid(element));
        document.getElementById("CheckAll").addEventListener("change", function () {
            document.querySelectorAll("[id^='Check_'").forEach(checkbox => checkbox.checked = this.checked);
        });
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            console.log("inside event listener")
            // Wait for the grid to be fully rendered
            setTimeout(function () {
                const rows = document.querySelectorAll("tr");
                rows.forEach(row => {
                    const statusCell = row.querySelector("td:nth-child(5) a"); // Assuming status is the 5th column
                    if (statusCell) {
                        const status = statusCell.textContent;
                        if (status === "Approved") {
                            row.classList.add("bg-approved");
                        } else if (status === "Pending") {
                            row.classList.add("bg-pending");
                        } else if (status === "Rejected") {
                            row.classList.add("bg-rejected");
                        }
                    }
                });
            }, 1000); // Adjust timeout as needed to ensure the grid is rendered
        });
    </script>
</body>
</html>

