@model List<EmployeeApp.PortalWithAuth.Models.AppliedProgram>
<html>
    <head></head>
    <body >
        <div class="p-2">
        @{
            if (Model.Count > 0)
            {
                <ul>
                    <h4>You have applied for the following programs.</h4>
                    @{
                        foreach (var item in Model)
                        {
                            <li>@item.programName</li>
                        }

                    }
                </ul>
            }
            else
            {
                <p class="text-danger">You have not yet applied for any programs!<a asp-action="ApplyStandard">Apply here.</a></p>
            }
        }

    </div>
        
        
    </body>
</html>



           